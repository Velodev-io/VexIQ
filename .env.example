# VexIQ Service
VEXIQ_PORT=8767
VEXIQ_DB_PATH=~/.vexiq/vexiq.db
VEXIQ_LOG_LEVEL=INFO

# Routing config
VEXIQ_MIN_DECISIONS_BEFORE_SCORING=5
VEXIQ_REVERT_WINDOW_MINUTES=60
VEXIQ_BUILD_FAILURE_WINDOW_MINUTES=5
VEXIQ_HEAVY_EDIT_THRESHOLD=0.5

# Default provider priority (cold start fallback)
VEXIQ_DEFAULT_PROVIDER_PRIORITY=claude,gpt-4o,ollama/llama3.2

# VexCTX integration
VEXCTX_BASE_URL=http://localhost:8765
VEXIQ_VEXCTX_SYNC_ENABLED=true

# Score weights
VEXIQ_WEIGHT_REVERT=2.0
VEXIQ_WEIGHT_MISTAKE=1.5
VEXIQ_WEIGHT_MODIFICATION=0.5
VEXIQ_WEIGHT_CONFIDENCE=0.3

# Time decay for scoring (days)
VEXIQ_SCORE_DECAY_HALFLIFE_DAYS=30
